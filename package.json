{
  "name": "@einhasad-vue/datatable-vue",
  "version": "0.4.2",
  "description": "A flexible, configurable grid component library for Vue 3 applications with support for both cursor and page-based pagination, custom data providers, and extensive customization options.",
  "author": "Dima Popov",
  "license": "MIT",
  "type": "module",
  "main": "./dist/grid.umd.cjs",
  "module": "./dist/grid.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/grid.js",
      "require": "./dist/grid.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./grid-default-styles.css": "./dist/grid-default-styles.css",
    "./themes/classic.css": "./dist/themes/classic.css",
    "./themes/material.css": "./dist/themes/material.css",
    "./themes": {
      "import": "./dist/grid.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "vue",
    "vue3",
    "datatable",
    "grid",
    "table",
    "pagination",
    "data-provider",
    "typescript",
    "cursor-pagination",
    "page-pagination"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/einhasad/vue-datatable.git"
  },
  "bugs": {
    "url": "https://github.com/einhasad/vue-datatable/issues"
  },
  "homepage": "https://github.com/einhasad/vue-datatable#readme",
  "scripts": {
    "dev": "vite",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts",
    "build": "vite build && npm run postbuild",
    "postbuild": "rm -rf dist/node_modules dist/vite.config.d.ts dist/vite.config.d.ts.map dist/__VLS_types.d.ts dist/mocks dist/mockServiceWorker.js",
    "prepare": "npm run build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "lint:fix": "eslint . --ext .vue,.ts,.tsx --fix",
    "knip": "knip"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.5.1",
    "fast-check": "^4.6.0",
    "happy-dom": "^18.0.1",
    "jsdom": "^27.2.0",
    "knip": "^6.3.1",
    "msw": "^2.12.14",
    "shiki": "^4.0.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.46.4",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^3.2.4",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "vue-tsc": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
